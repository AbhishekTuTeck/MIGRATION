@page "/sch10.3-block-4"
@layout Migration.Components.Layout.AuthenticatedLayout


<div class="main-content">
    <SurveryTopHeader />

    @* block-4*@
    <div class="card custom-card">
        <div class="card-header">
            <h3 class="card-title">
                <span class="text-primary me-2">[Block - 4]</span> Household characteristics
            </h3>
        </div>
        <div class="card-body p-1">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0 align-middle">
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td colspan="2">Household Size</td>
                            <td>
                                <input class="form-control form-control-sm" />
                            </td>
                        </tr>
                        <tr>
                            <td>2</td>
                            <td colspan="2">Household Religion</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Hinduism</option>
                                    <option value="2">2 - Islam</option>
                                    <option value="3">3 - Christianity</option>
                                    <option value="4">4 - Sikhism</option>
                                    <option value="5">5 - Jainism</option>
                                    <option value="6">6 - Buddhism</option>
                                    <option value="7">7 - Zoroastrianism</option>
                                    <option value="9">9 - Others</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>3</td>
                            <td colspan="2">Household Social Group</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Scheduled Tribe (ST)</option>
                                    <option value="2">2 - Scheduled Caste (SC)</option>
                                    <option value="3">3 - Other Backward Class (OBC)</option>
                                    <option value="9">9 - Others</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>4</td>
                            <td colspan="2">
                                <p class="mb-0 fw-bold">Area type in which the dwelling unit is located (code)</p>
                            </td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Notified slum</option>
                                    <option value="2">2 - Non-notified slum</option>
                                    <option value="3">3 - Squatter settlement</option>
                                    <option value="9">9 - Other areas</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>5</td>
                            <td colspan="2">Whether the household migrated to the village/town of enumeration during the last 365 days. (yes- 1, no- 2)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Yes</option>
                                    <option value="2">2 - No</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>6</td>
                            <td rowspan="3">
                                <p class="mb-0 fw-bold">If code 1 in item 5</p>
                            </td>
                            <td>Location of last usual place of residence (code)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Same district (rural)</option>
                                    <option value="2">2 - Same district (urban)</option>
                                    <option value="3">3 - Same state, another district (rural)</option>
                                    <option value="4">4 - Same state, another district (urban)</option>
                                    <option value="5">5 - Another state (rural)</option>
                                    <option value="6">6 - Another state (urban)</option>
                                    <option value="7">7 - Another country</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>7</td>
                            <td>Pattern of migration (code)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Temporary</option>
                                    <option value="2">2 - Permanent</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>8</td>
                            <td>Reason for migration (code)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="01">01 - Search of employment</option>
                                    <option value="02">02 - Search of better employment</option>
                                    <option value="03">03 - Business</option>
                                    <option value="04">04 - To take up employment / better employment</option>
                                    <option value="05">05 - Transfer of service/contract</option>
                                    <option value="06">06 - Proximity to place of work</option>
                                    <option value="07">07 - Studies</option>
                                    <option value="08">08 - Natural disaster</option>
                                    <option value="10">10 - Social/political problems</option>
                                    <option value="11">11 - Displacement by development project</option>
                                    <option value="12">12 - Scarcity of water</option>
                                    <option value="13">13 - Acquisition of own house/flat</option>
                                    <option value="14">14 - Housing problems</option>
                                    <option value="15">15 - Health care</option>
                                    <option value="16">16 - Post-retirement</option>
                                    <option value="17">17 - Marriage</option>
                                    <option value="18">18 - Migration of parent/earning member</option>
                                    <option value="19">19 - Others</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>9</td>
                            <td colspan="2">Whether any former member of the household migrated out any time in the past (yes - 1, no – 2)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Yes</option>
                                    <option value="2">2 - No</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td>10</td>
                            <td rowspan="4">
                                <p class="mb-0 fw-bold">If code 1 in item 9</p>
                            </td>
                            <td>Number of male members who migrated out </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" />
                            </td>
                        </tr>
                        <tr>
                            <td>11</td>
                            <td>Number of female members who migrated out</td>
                            <td>
                                <input type="number" class="form-control form-control-sm" />
                            </td>
                        </tr>
                        <tr>
                            <td>12</td>
                            <td>Number of transgender members who migrated out </td>
                            <td>
                                <input type="number" class="form-control form-control-sm" />
                            </td>
                        </tr>
                        <tr>
                            <td>13</td>
                            <td>Whether received remittances at least once during the last 365 days from the members who migrated out (yes - 1, no - 2)</td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="1">1 - Yes</option>
                                    <option value="2">2 - No</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
                            <td rowspan="5">14</td>
                            <td colspan="2" rowspan="5">
                                <p class="mb-0">
                                    <span class="fw-bold">If 1 in item 13, </span> use of remittances(maximum five codes in descending order of amount used)
                                </p>
                            </td>
                            <td>
                                <select class="form-select form-select-sm">
                                    <option value="">-- Select --</option>
                                    <option value="01">01 - Food items</option>
                                    <option value="02">02 - Education</option>
                                    <option value="03">03 - Household durable</option>
                                    <option value="04">04 - Marriage/ceremonies</option>
                                    <option value="05">05 - Health care</option>
                                    <option value="06">06 - Other consumer expenditure</option>
                                    <option value="07">07 - Improving housing condition</option>
                                    <option value="08">08 - Debt repayment</option>
                                    <option value="10">10 - Financing working capital</option>
                                    <option value="11">11 - New entrepreneurial activity</option>
                                    <option value="12">12 - Saving/investment</option>
                                    <option value="19">19 - Others</option>
                                    <option value="99">99 - No second/third/fourth/fifth use</option>
                                </select>
                            </td>
                        </tr>
                        <tr>
