                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">12</span> Sample Sub-Division Number</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item12" @onchange="Block1_Item12_SubDivisionNo_Changed" />
                        </div>
                    </div>

                    <!-- 13 Second Stage Stratum Number -->
