                                    <option value="1">1 - Informant busy</option>
                                    <option value="2">2 - Members away</option>
                                    <option value="3">3 - Non-cooperative</option>
                                    <option value="9">9 - Others</option>
                                </InputSelect>
                            </div>
                        </div>

                        @if ((Model.Item16 ?? "").Equals("9"))
                        {
                            <div class="col-sm-12">
                                <div class="mb-3">
                                    <label class="form-label">Others</label>
                                    <InputText class="form-control form-control-sm" placeholder="Enter Other Reason" @bind-Value="Model.Item17" @onchange="Block1_Item16_Others_Changed" />
                                </div>
                            </div>
                        }
