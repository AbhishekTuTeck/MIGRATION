@page "/sch10.3-block-1"
@layout Migration.Components.Layout.AuthenticatedLayout

@using BootstrapBlazor.Components
@using Migration.Models
@* @using Migration.DTOs *@

@* @inject ISchedule10_3Service ScheduleService *@
@inject NavigationManager navigationManager

<div class="main-content">
    <SurveryTopHeader />

    <EditForm Model="Model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div class="card custom-card">
            <div class="card-header">
                <h3 class="card-title">
                    <span class="text-primary fw-bolder me-2">[Block 1]</span>
                    Identification of sample household
                </h3>
            </div>

            <div class="card-body">
                <div class="row">

                    <!-- 1 Sector (Rural-1, Urban -2) -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label">
                                <span class="form-badge">1</span> Sector (Rural-1, Urban -2)
                            </label>
                            <InputText class="form-control form-control-sm" @bind-Value="Model.Item1" @onchange="Block1_Item1_Sector_Changed" />
                        </div>
                    </div>

                    <!-- 2 Type of Sample -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">2</span> Type of Sample</label>
                            <InputText class="form-control form-control-sm" @bind-Value="Model.Item2" @onchange="Block1_Item2_TypeOfSample_Changed" />
                        </div>
                    </div>

                    <!-- 3 State/U.T. Name -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">3</span> State/U.T. Name</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item3" @onchange="Block1_Item3_StateName_Changed" />
                        </div>
                    </div>

                    <!-- 4 District Name -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">4</span> District Name</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item4" @onchange="Block1_Item4_DistrictName_Changed" />
                        </div>
                    </div>

                    <!-- 5 Sub-District/Tehsil/Town -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">5</span> Name of Sub-District/Tehsil/Town</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item5" @onchange="Block1_Item5_SubDistrict_Changed" />
                        </div>
                    </div>

                    <!-- 6 Village Name -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">6</span> Village Name</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item6" @onchange="Block1_Item6_Village_Changed" />
                        </div>
                    </div>

                    <!-- 7 Investigator Unit Number/Block Number -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">7</span> Investigator Unit Number/Block Number:</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item7" @onchange="Block1_Item7_InvestigatorUnitNo_Changed" />
                        </div>
                    </div>

                    <!-- 8 Sample Sub-Unit (SU) Number -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">8</span> Sample Sub-Unit (SU) Number</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item8" @onchange="Block1_Item8_SUNumber_Changed" />
                        </div>
                    </div>

                    <!-- 9 Round Number -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">9</span> Round Number</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item9" @onchange="Block1_Item9_RoundNumber_Changed" />
                        </div>
                    </div>

                    <!-- 10 Schedule name/Module -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">10</span> Schedule name/Module</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item10" @onchange="Block1_Item10_ScheduleName_Changed" />
                        </div>
                    </div>

                    <!-- 11 Serial Number of Sample FSU -->
                    <div class="col-sm-6">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">11</span> Serial Number of Sample FSU</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item11" @onchange="Block1_Item11_FSU_SerialNo_Changed" />
                        </div>
                    </div>

                    <!-- 12 Sample Sub-Division Number -->
