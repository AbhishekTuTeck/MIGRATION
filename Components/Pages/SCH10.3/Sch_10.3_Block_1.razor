                        </div>
                    </div>

                    <!-- 14 Household No -->
                    <div class="col-sm-12">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">14</span>Sample Household Number</label>
                            <InputText class="form-control form-control-sm" disabled @bind-Value="Model.Item14" />
                        </div>
                    </div>

                    <!-- 15 Survey Code -->
                    <div class="col-sm-12">
                        <div class="mb-3">
                            <label class="form-label"><span class="form-badge">15</span> Survey Code</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="Model.Item15" @onchange="Block1_Item15_SurveyCode_Changed">
                                <option value="">-- Select --</option>
                                <option value="1">1 - Original</option>
                                <option value="2">2 - Substitute</option>
                                <option value="3">3 - Casualty</option>
                            </InputSelect>
                        </div>
                    </div>

                    @if ((Model.Item15 ?? "").Equals("2") || (Model.Item15 ?? "").Equals("3"))
                    {
                        <!-- 16 -->
                        <div class="col-sm-12">
                            <div class="mb-3">
                                <label class="form-label"><span class="form-badge">16</span> Reason</label>
                                <InputSelect class="form-select form-select-sm" @bind-Value="Model.Item16" @onchange="Block1_Item16_ReasonCode_Changed">
