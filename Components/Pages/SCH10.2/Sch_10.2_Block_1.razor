                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">12</span>Sample Sub-Division Number</label>
                        <input type="text" class="form-control form-control-sm" value="" disabled>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">13</span>Second Stage Stratum Number</label>
                        <input type="text" class="form-control form-control-sm" disabled>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">14</span>Sample Household Number</label>
                        <input type="text" class="form-control form-control-sm" disabled />
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">15</span>Survey Code</label>
                        <select class="form-select form-select-sm">
                            <option value="">-- Select --</option>
                            <option value="1">1 - Original</option>
                            <option value="2">2 - Substitute</option>
                            <option value="3">3 - Casualty</option>
                        </select>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">16</span>Reason for substitution/casualty of the original household<span class="text-danger ms-1">*</span></label>
                        <select class="form-select form-select-sm">
                            <option value="">-- Select --</option>
                            <option value="1">1 - Informant busy</option>
                            <option value="2">2 - Members away from home</option>
                            <option value="3">3 - Informant non-cooperative</option>
                            <option value="9">9 - Others</option>
                        </select>
                        <div class="form-text"><span class="text-danger">*</span>The interviewer will fill up this item if a substituted household is canvassed or the household is a casualty</div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div>
                        <label class="form-label">Others</label>
                        <input type="text" class="form-control form-control-sm" />
                        <div class="form-text">If code 9 in item 16,</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

