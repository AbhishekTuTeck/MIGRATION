                        <input type="text" class="form-control form-control-sm" disabled>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">10</span>Schedule name/Module</label>
                        <input type="text" class="form-control form-control-sm" disabled>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="mb-3">
                        <label class="form-label"><span class="form-badge">11</span>Serial Number of Sample FSU</label>
                        <input type="text" class="form-control form-control-sm" disabled>
                    </div>
                </div>
