@page "/sch10.1-block-3"
@layout Migration.Components.Layout.AuthenticatedLayout


<div class="main-content">
    <div>
        <div class="d-flex align-items-center mb-3">
            <NavLink class="btn btn-outline-secondary btn-sm me-2" @onclick="@(() => navigationManager.NavigateTo("/sch10.1-block-3"))">
