        <div class="card-header">
            <h3 class="card-title">
                <span class="text-primary me-2">[Block 3]</span>Demographic and other particulars of household members
            </h3>
            <div class="card-tools">
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addMigrationBlock3Modal"><i class="fi fi-rr-plus me-1"></i>Add</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0 align-middle">
                    <thead>
                        <tr>
                            <th rowspan="2">Sl. No.</th>
                            <th rowspan="2">Name of household member</th>
                            <th rowspan="2" style="min-width: 115px;">Relation to head (code)</th>
                            <th rowspan="2" style="min-width: 115px;">Gender (code)</th>
                            <th rowspan="2">
                                Age
                                (years)
                            </th>
                            <th rowspan="2">Marital status(code)</th>
                            <th rowspan="2">Highest level of education Completed successfully(code)</th>
                            <th rowspan="2">Number of years in formal education</th>
                            <th rowspan="2">
                                <p class="mb-0 fw-bold">For persons age 0 to 29 years, status of current attendance(code)</p>
                            </th>
                            <th rowspan="2">Principal activity status (code)</th>
                            <th colspan="2" class="text-center">For codes 11-51 in Col 10</th>
                            <th rowspan="2">Action</th>
                        </tr>
                        <tr>
                            <th>Industry division (2-digit NIC 2025)</th>
                            <th>Occupation(3-digit NCO-2015)</th>
                        </tr>
                        <tr>
                            <th>(1)</th>
                            <th>(2)</th>
                            <th>(3)</th>
                            <th>(4)</th>
                            <th>(5)</th>
                            <th>(6)</th>
                            <th>(7)</th>
                            <th>(8)</th>
                            <th>(9)</th>
                            <th>(10)</th>
                            <th>(11)</th>
                            <th>(12)</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td>Samaira</td>
                            <td>1</td>
                            <td>2</td>
                            <td>46</td>
                            <td>2</td>
                            <td>12</td>
                            <td>2</td>
                            <td>14</td>
                            <td>31</td>
                            <td>22</td>
                            <td>234</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <button class="btn btn-outline-primary me-2"><i class="fi fi-rr-pencil"></i></button>
                                    <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#alertModal"><i class="fi fi-rr-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>1</td>
                            <td>Samir</td>
                            <td>2</td>
                            <td>1</td>
                            <td>46</td>
                            <td>2</td>
                            <td>12</td>
                            <td>2</td>
                            <td>14</td>
                            <td>31</td>
