<!-- Modal -->
<div class="modal fade" id="validationModal" tabindex="-1" aria-labelledby="validationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="validationModalLabel">Validate</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
       <!-- Warnings Section -->
<div class="card border-warning mb-4">
  <div class="card-header bg-warning-subtle d-flex align-items-center gap-2">
   <span class="rounded-circle bg-warning text-dark d-flex align-items-center justify-content-center"
          style="width:36px;height:36px;">
      <i class="fi fi-rr-triangle-warning"></i>
    </span>
    <div>
      <h6 class="mb-0 fw-semibold">6 Warning Found</h6>
      <small class="text-muted">Validation failed – Please Fix all Warning</small>
    </div>
  </div>

  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered table-hover mb-0 align-middle">
        <thead class="table-warning">
          <tr>
            <th style="width:80px">Sl No.</th>
            <th>Warning Description</th>
            <th style="width:90px">Row No</th>
            <th style="width:80px">Block</th>
            <th style="width:80px" class="text-center">Warning</th>
            <th style="width:180px">Remarks</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td>First 4 Digit (Item 4) of NIC 5 Digit (Item 5) is not matching</td>
            <td>5</td>
            <td>A</td>
            <td class="text-center text-warning">⚠</td>
            <td><input type="text" class="form-control form-control-sm" value="OK"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Errors Section -->
<div class="card border-danger">
  <div class="card-header bg-danger-subtle d-flex align-items-center gap-2">
    <span class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center"
          style="width:36px;height:36px;">
      <i class="fi fi-rr-cross-circle"></i>
    </span>
    <div>
      <h6 class="mb-0 fw-semibold">3 Errors Found</h6>
      <small class="text-muted">Validation failed – Please Fix all Error</small>
    </div>
  </div>

  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered table-hover mb-0 align-middle">
        <thead class="table-danger">
          <tr>
            <th style="width:80px">Sl No.</th>
            <th>Error Description</th>
            <th style="width:90px">Row No</th>
            <th style="width:80px">Block</th>
            <th style="width:80px" class="text-center">Error</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>1</td>
            <td>First 4 Digit (Item 4) of NIC 5 Digit (Item 5) is not matching</td>
            <td>5</td>
            <td>A</td>
            <td class="text-center text-danger"> <i class="fi fi-rr-cross-circle"></i></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary">Save changes</button>
      </div>
    </div>
  </div>
</div>
